{
  "name": "the-lab-barbershop-website",
  "version": "2.0.0",
  "description": "The Lab Barbershop - Premium barbershop website for Manor, TX",
  "scripts": {
    "dev": "npm run css:build && npx @11ty/eleventy --serve",
    "build": "npm run css:build && npx @11ty/eleventy",
    "css:build": "npx tailwindcss -i ./src/assets/css/style.css -o ./_site/assets/css/style.css --minify"
  },
  "keywords": [
    "barbershop",
    "manor",
    "texas",
    "fades"
  ],
  "author": "The Lab Barbershop",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "luxon": "^3.7.2"
  }
}